# PostgreSQL (lokaal of Railway: kopieer de DATABASE_URL uit het Postgres-plugin scherm)
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/radio?schema=public"

# Gebruikt voor JWT-tokens (minimaal 16 tekens; in productie: lang en willekeurig)
JWT_SECRET="vervang-dit-door-een-lange-willekeurige-string"

# Optioneel: duur van het token (standaard 7d)
# JWT_EXPIRES_DAYS=7

# Poort (Railway zet PORT automatisch)
PORT=3000

# Optioneel: bind-adres (Railway: 0.0.0.0 — dit is ook de standaard in server.js)
# HOST=0.0.0.0

# Eerste super admin (npm run db:seed)
# SEED_SUPER_EMAIL=admin@sonicwave.local
# SEED_SUPER_PASSWORD=changeme-admin
# SEED_SUPER_NAME=Super Admin
