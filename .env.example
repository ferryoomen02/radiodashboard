# PostgreSQL (lokaal of Railway: kopieer de DATABASE_URL uit het Postgres-plugin scherm)
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/radio?schema=public"

# Gebruikt voor JWT-tokens (minimaal 16 tekens; in productie: lang en willekeurig)
JWT_SECRET="vervang-dit-door-een-lange-willekeurige-string"

# Optioneel: duur van het token (standaard 7d)
# JWT_EXPIRES_DAYS=7

# Poort (Railway zet PORT automatisch)
PORT=3000

# Optioneel: bind-adres (Railway: 0.0.0.0 — dit is ook de standaard in server.js)
# HOST=0.0.0.0

# Bestaande gebruiker permanent SUPER_ADMIN maken (eenmalig, met juiste DATABASE_URL):
#   npm run db:promote-super
# Of: node scripts/promote-super-admin.mjs jouw@email.nl

# Eerste super admin (npm run db:seed)
# SEED_SUPER_EMAIL=admin@sonicwave.local
# SEED_SUPER_PASSWORD=changeme-admin
# SEED_SUPER_NAME=Super Admin

# Publieke basis-URL voor uitnodigingslinks (verplicht op productie / Railway voor correcte mail-URLs)
# Railway: stel in onder Variables — gebruik je publieke HTTPS-URL zonder slash aan het eind
# PUBLIC_APP_URL=https://jouw-service.up.railway.app

# ——— Multi-tenant (subdomeinen per zender) ———
# Apex-domein waartegen subdomeinen worden afgeleid, bv. easyfm.jouwplatform.nl → slug "easyfm"
# Zonder deze variabele: lokaal werkt *.localhost als zender-subdomein (bv. easyfm.localhost:3000)
# PUBLIC_BASE_DOMAIN=jouwplatform.nl
#
# Optioneel: vaste URL van het centrale beheer (dashboard.domein.nl) — voor super admins op een zender-subdomein
# CENTRAL_PORTAL_URL=https://dashboard.jouwplatform.nl


# SMTP voor echte uitnodigingsmails (Railway: gebruik je mailprovider of transactional SMTP)
# Zonder deze variabelen: uitnodiging wordt aangemaakt en de ruwe link staat in de API-response en console.
#
# Typische providers: SendGrid SMTP, Mailgun SMTP, Postmark SMTP, Amazon SES SMTP, of je eigen mailserver.
#
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=apikey
# SMTP_PASS=SG.xxxx
# SMTP_FROM="SonicWave <noreply@jouwdomein.nl>"
#
# Voor lokale tests kun je Mailpit/Mailhog gebruiken; zet SMTP_HOST naar die service.
