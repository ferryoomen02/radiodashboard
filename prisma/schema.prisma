datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  SUPER_ADMIN
  STATION_ADMIN
  STAFF
}

enum InviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
}

enum StationStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

model User {
  id           String       @id @default(cuid())
  name         String
  email        String       @unique
  passwordHash String
  role         Role         @default(STAFF)
  stationId    String?
  station      Station?     @relation(fields: [stationId], references: [id])
  /// JSON-array van module-keys die deze gebruiker mag gebruiken (voor STAFF binnen een zender).
  permissions  Json         @default("[]")
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  mediaAssets  MediaAsset[]

  @@index([stationId])
  @@index([role])
}

/// Bedrijf (tenant); zenders hangen hieronder.
model Company {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  /// Uitbreidbaar: logoUrl, contactEmail, notes, …
  metadata  Json      @default("{}")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  stations  Station[]
}

/// Ingeschakelde functies: relationeel in StationFeature; enabledFeatures is gedenormaliseerde cache (zelfde volgorde als keys).
model Station {
  id              String          @id @default(cuid())
  companyId       String
  company         Company         @relation(fields: [companyId], references: [id], onDelete: Restrict)
  name            String
  slug            String          @unique
  status          StationStatus   @default(ACTIVE)
  description     String?
  /// Publiek zichtbaar logo (URL); subdomein-site en login.
  publicLogoUrl   String?
  /// Hex kleur, bv. #1a1a1a — hero/achtergrond accent.
  primaryColor    String?
  /// Hex accent, bv. #da2e20 — knoppen/links.
  accentColor     String?
  /// Optioneel eigen hostnaam voor deze zender (bv. www.easyfm.nl). DNS + HTTPS bij hosting configureren.
  customPublicHost String? @unique
  currentTrackId  String?
  enabledFeatures Json            @default("[]")
  stationFeatures StationFeature[]
  users           User[]
  tracks          Track[]
  history         PlayHistory[]
  mediaAssets     MediaAsset[]

  @@index([companyId])
  @@index([status])
}

/// Welke feature-keys (FeatureDefinition.key) staan aan voor deze zender.
model StationFeature {
  stationId  String
  station    Station @relation(fields: [stationId], references: [id], onDelete: Cascade)
  featureKey String
  createdAt  DateTime @default(now())

  @@id([stationId, featureKey])
  @@index([featureKey])
}

model Track {
  id              String        @id @default(cuid())
  stationId       String
  station         Station       @relation(fields: [stationId], references: [id], onDelete: Cascade)
  artist          String
  title           String
  durationSeconds Int?
  createdAt       DateTime      @default(now())
  historyEntries  PlayHistory[]

  @@index([stationId])
}

model PlayHistory {
  id        String   @id @default(cuid())
  stationId String
  station   Station  @relation(fields: [stationId], references: [id], onDelete: Cascade)
  trackId   String
  track     Track    @relation(fields: [trackId], references: [id], onDelete: Cascade)
  playedAt  DateTime @default(now())

  @@index([stationId, playedAt])
}

/// Catalogus: vaste + door super toegevoegde feature-keys met label voor UI.
model FeatureDefinition {
  id          String   @id @default(cuid())
  key         String   @unique
  label       String
  description String?
  isBuiltIn   Boolean  @default(false)
  createdAt   DateTime @default(now())
}

/// Uitnodiging voor registratie; token alleen als hash opgeslagen.
model InviteToken {
  id          String       @id @default(cuid())
  email       String
  tokenHash   String       @unique
  role        Role         @default(SUPER_ADMIN)
  status      InviteStatus @default(PENDING)
  expiresAt   DateTime
  usedAt      DateTime?
  emailSentAt DateTime?
  emailError  String?
  createdById String?
  createdAt   DateTime     @default(now())
}

/// Singleton platform / portal (branding, vaste teksten); `texts` JSON voor uitbreiding.
model PlatformSettings {
  id             String   @id @default("default")
  logoStorageKey String?
  platformName   String   @default("SonicWave")
  subtitle       String   @default("Platform")
  texts          Json     @default("{}")
  updatedAt      DateTime @updatedAt
}

/// Geüploade mediabestanden per zender (uitbreidbaar voor DJ, nieuws, site).
model MediaAsset {
  id          String   @id @default(cuid())
  stationId   String
  station     Station  @relation(fields: [stationId], references: [id], onDelete: Cascade)
  filename    String
  storageKey  String   @unique
  mimeType    String
  sizeBytes   Int
  width       Int?
  height      Int?
  title       String?
  altText     String?
  createdById String?
  createdBy   User?    @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())

  @@index([stationId, createdAt])
}
